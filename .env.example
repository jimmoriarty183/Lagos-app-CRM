# Paddle Payment Integration
# Add this to .env.local with your actual Paddle client token

# Get this from: https://dashboard.paddle.com/setup/tokens
# It should start with 'live_' for production or 'test_' for sandbox
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=your_client_token_here

# Example: 
# NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=live_xxxxx...
